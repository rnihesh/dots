#!/usr/bin/env bash

set -e

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
  echo "ollaman - Interact with Ollama AI models via terminal"
  exit 0
fi

API="http://localhost:11434"
GEN_ENDPOINT="$API/api/generate"

die() {
  echo "✗ $1"
  exit 1
}

spinner() {
  local pid=$1
  local spinstr='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  local i=0
  while kill -0 $pid 2>/dev/null; do
    printf "\r${spinstr:$i:1}"
    i=$(( (i+1) % ${#spinstr} ))
    sleep 0.1
  done
  printf "\r"
}

ask() {
  read -e -p "$1 " ans
  echo "$ans"
}

# --- dependency check ---
for cmd in curl jq fzf; do
  command -v "$cmd" >/dev/null 2>&1 || die "$cmd not installed"
done

# --- check ollama ---
if ! curl -s "$API/api/tags" >/dev/null 2>&1; then
  choice=$(printf "start\nexit\n" | fzf --prompt="⚠ Ollama is not running. Start it? ")

  if [[ "$choice" == "start" ]]; then
    ollama serve >/dev/null 2>&1 &
    sleep 2
    curl -s "$API/api/tags" >/dev/null 2>&1 || die "Failed to start Ollama"
    echo "✓ Ollama started"
  else
    echo "✗ Exiting"
    exit 0
  fi
fi

# --- model selection ---
model=$(curl -s "$API/api/tags" \
  | jq -r '.models[].name' \
  | fzf --prompt="Select model: ")

[ -z "$model" ] && exit 0

# --- optional file ---
file=$( (echo "Skip"; ls -A) | fzf --prompt="Select file (or Skip): " )

file_content=""
if [[ "$file" != "Skip" && -n "$file" && -f "$file" ]]; then
  file_content=$(cat "$file")
fi

# --- prompt ---
prompt=$(ask "Enter prompt:")
[ -z "$prompt" ] && die "Empty prompt"

# --- mode ---
mode=$(printf "stream\nno-stream\n" | fzf --prompt="Output mode: ")
[ -z "$mode" ] && exit 0

final_prompt="$prompt"
if [[ -n "$file_content" ]]; then
  final_prompt="$final_prompt

--- FILE: $file ---
$file_content
--- END FILE ---"
fi

echo "⚠ Generating…"

# --- streaming ---
if [[ "$mode" == "stream" ]]; then
  echo "✓ Streaming output"
  curl -s "$GEN_ENDPOINT" -d "$(jq -n \
    --arg model "$model" \
    --arg prompt "$final_prompt" \
    '{model:$model, prompt:$prompt, stream:true}')" \
  | while read -r line; do
      chunk=$(echo "$line" | jq -r '.response // empty')
      if [[ -n "$chunk" ]]; then
        printf "%s" "$chunk"
      fi
    done
  printf "\n"
else
  echo "✓ Rendering output"
  curl -s "$GEN_ENDPOINT" -d "$(jq -n \
    --arg model "$model" \
    --arg prompt "$final_prompt" \
    '{model:$model, prompt:$prompt, stream:false}')" \
    > /tmp/ollama_response.json &
  spinner $!
  response=$(cat /tmp/ollama_response.json | jq -r '.response')
  rm /tmp/ollama_response.json
  if command -v glow >/dev/null 2>&1; then
    echo "$response" | glow -
  else
    echo "$response"
  fi
fi
